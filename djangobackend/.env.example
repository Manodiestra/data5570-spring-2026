# AWS Cognito Configuration
# Copy this file to .env and fill in your actual values

# AWS Cognito Region (e.g., us-east-1, us-west-2)
COGNITO_REGION=us-east-1

# AWS Cognito User Pool ID (found in AWS Cognito Console)
COGNITO_USER_POOL_ID=us-east-1_asdfasdf

# AWS Cognito App Client ID (found in AWS Cognito Console under App clients)
COGNITO_APP_CLIENT_ID=your_app_client_id_here

# AWS S3 Configuration
# These are required for image uploads
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-bucket-name-here
# Keys from your S3 Uploader IAM user:
AWS_ACCESS_KEY_ID=your-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here

ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Stripe (test mode) — keys from https://dashboard.stripe.com/test/apikeys
# Do not commit real keys.
#
# Checkout redirects: Stripe sends the *browser* to these URLs after pay / cancel.
# Test mode usually allows http://localhost — fine for Expo web (`npx expo start --web`),
# default dev server is http://localhost:8081. Keep Expo running so the page loads.
# Use {CHECKOUT_SESSION_ID} in the success URL if you want Stripe to append the session id.
#
# If you pay from a phone/emulator, localhost is the device itself — use your PC’s LAN IP
# (e.g. http://192.168.1.5:8081/...) or an HTTPS tunnel (ngrok, etc.) instead.
STRIPE_SECRET_KEY=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:8081/events?checkout=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:8081/events?checkout=cancel
