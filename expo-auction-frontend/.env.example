# Django REST API base URL (no trailing slash), e.g. http://192.168.1.5:8000/api
EXPO_PUBLIC_DJANGO_API_URL=http://localhost:8000/api

# Stripe (optional for this app): Hosted Checkout opens in the browser; the publishable
# key is only needed if you add client-side Stripe.js. Secret key stays on Django only.
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# AWS Cognito Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# AWS Cognito Region (e.g., us-east-1, us-west-2)
EXPO_PUBLIC_COGNITO_REGION=us-east-1

# AWS Cognito User Pool ID
# Found in AWS Cognito Console under your User Pool
EXPO_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xQf6ajVGZ

# AWS Cognito App Client ID
# Found in AWS Cognito Console under App integration > App clients
EXPO_PUBLIC_COGNITO_CLIENT_ID=your_app_client_id_here

# Optional: only if you use Cognito Hosted UI / OAuth redirects
# EXPO_PUBLIC_COGNITO_USER_POOL_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com
